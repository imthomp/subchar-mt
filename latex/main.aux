\@writefile{lot}{\contentsline {table}{\numberline {2}{\ignorespaces Main Zh$\to $En results at $n=1000$, averaged over 5 seeds. COMET (wmt22-comet-da) scores are typically in the range 0--1 for reasonable translations; higher is better. The raw-character baseline achieves the best COMET in every condition. Bootstrap $p$-values for COMET differences are all $>0.46$ for morphemes/SP, indicating the small improvements are not statistically significant; for radicals, $p<0.001$ (not shown---differences are $>$10$\sigma $ in absolute terms).}}{4}{table.caption.8}\protected@file@percent }
\newlabel{tab:main}{{2}{4}{Main Zh$\to $En results at $n=1000$, averaged over 5 seeds. COMET (wmt22-comet-da) scores are typically in the range 0--1 for reasonable translations; higher is better. The raw-character baseline achieves the best COMET in every condition. Bootstrap $p$-values for COMET differences are all $>0.46$ for morphemes/SP, indicating the small improvements are not statistically significant; for radicals, $p<0.001$ (not shown---differences are $>$10$\sigma $ in absolute terms)}{table.caption.8}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces $\Delta $BLEU vs.\ $\Delta $COMET relative to the raw-character baseline, across all training sizes (circles: $n=50$, squares: $n=250$, triangles: $n=1000$). Every point lies in the lower-left quadrant or below the $x$-axis: BLEU and COMET move in the same direction (both decline), but BLEU declines \textit  {less} than COMET for morphemes and SentencePiece, consistent with the token-count inflation artifact. Radicals (red) fall far below the $x$-axis with COMET collapsing by up to $-0.55$.}}{4}{figure.caption.9}\protected@file@percent }
\newlabel{fig:delta_scatter}{{1}{4}{$\Delta $BLEU vs.\ $\Delta $COMET relative to the raw-character baseline, across all training sizes (circles: $n=50$, squares: $n=250$, triangles: $n=1000$). Every point lies in the lower-left quadrant or below the $x$-axis: BLEU and COMET move in the same direction (both decline), but BLEU declines \textit {less} than COMET for morphemes and SentencePiece, consistent with the token-count inflation artifact. Radicals (red) fall far below the $x$-axis with COMET collapsing by up to $-0.55$}{figure.caption.9}{}}
